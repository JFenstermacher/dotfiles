# Strict peer dependency checking — fail on missing peers instead of warning.
# Forces every workspace package to explicitly declare its dependencies.
strict-peer-dependencies=true

# Automatically install peer dependencies when they're missing.
# Combined with strict-peer-deps=true above, this gives good DX without
# masking undeclared dependency relationships.
auto-install-peers=true
@jsr:registry=https://npm.jsr.io
