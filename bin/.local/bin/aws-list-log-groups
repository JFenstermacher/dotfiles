#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: aws-list-log-groups [OPTIONS]

List CloudWatch log groups.

Options:
  -p, --profile PROFILE   AWS profile (default: \$AWS_PROFILE)
  -r, --region REGION     AWS region (default: us-east-1)
  --tsv                   Output as tab-separated values (for scripting)
  -h, --help              Show this help
EOF
  exit 0
}

PROFILE="${AWS_PROFILE:-}"
REGION="us-east-1"
TSV=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--profile) PROFILE="$2"; shift 2 ;;
    -r|--region) REGION="$2"; shift 2 ;;
    --tsv) TSV=true; shift ;;
    -h|--help) usage ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$PROFILE" ]]; then
  echo "Error: --profile is required (set AWS_PROFILE or pass -p)" >&2
  exit 1
fi

AWS_ARGS=(--profile "$PROFILE" --region "$REGION")

if [[ "$TSV" == true ]]; then
  aws logs describe-log-groups \
    "${AWS_ARGS[@]}" \
    --query 'logGroups[*].[logGroupName,retentionInDays,storedBytes]' \
    --output text
else
  aws logs describe-log-groups \
    "${AWS_ARGS[@]}" \
    --query 'logGroups[*].[logGroupName,retentionInDays,storedBytes]' \
    --output table
fi
