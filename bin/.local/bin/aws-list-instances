#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: aws-list-instances [OPTIONS]

List EC2 instances reachable via SSM with their Name tags.

Options:
  -p, --profile PROFILE   AWS profile (default: \$AWS_PROFILE)
  -r, --region REGION     AWS region (default: us-east-1)
  -a, --all               Show all running instances, not just SSM-online
  --tsv                   Output as tab-separated values (for scripting)
  -h, --help              Show this help
EOF
  exit 0
}

PROFILE="${AWS_PROFILE:-}"
REGION="us-east-1"
ALL=false
TSV=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--profile) PROFILE="$2"; shift 2 ;;
    -r|--region) REGION="$2"; shift 2 ;;
    -a|--all) ALL=true; shift ;;
    --tsv) TSV=true; shift ;;
    -h|--help) usage ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$PROFILE" ]]; then
  echo "Error: --profile is required (set AWS_PROFILE or pass -p)" >&2
  exit 1
fi

if [[ "$TSV" == true ]]; then
  OUTPUT="text"
  QUERY='Reservations[*].Instances[*].[InstanceId,Tags[?Key==`Name`].Value|[0],PlatformDetails]'
else
  OUTPUT="table"
  QUERY='Reservations[*].Instances[*].[InstanceId,Tags[?Key==`Name`].Value|[0],PlatformDetails,State.Name]'
fi

if [[ "$ALL" == true ]]; then
  aws ec2 describe-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --filters Name=instance-state-name,Values=running \
    --query "$QUERY" \
    --output "$OUTPUT"
else
  INSTANCE_IDS=$(aws ssm describe-instance-information \
    --profile "$PROFILE" \
    --region "$REGION" \
    --filters Key=PingStatus,Values=Online \
    --query 'InstanceInformationList[*].InstanceId' \
    --output text)

  if [[ -z "$INSTANCE_IDS" ]]; then
    echo "No SSM-online instances found."
    exit 0
  fi

  aws ec2 describe-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --instance-ids $INSTANCE_IDS \
    --query "$QUERY" \
    --output "$OUTPUT"
fi
