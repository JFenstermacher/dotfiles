#!/usr/bin/env bun

import path from "node:path";
import { exec, execCapture, fzf, getWorktreeBranches, requireBareRepo, repoContext, sessionName, shellQuote, tmuxSwitchOrCreate } from "./utils.js";

const gitDir = requireBareRepo();
const ctx = repoContext(gitDir);
const currentWorktree = execCapture("git rev-parse --show-toplevel 2>/dev/null").replace(/\s+$/g, "");

const worktrees = getWorktreeBranches(gitDir);

const available = worktrees.filter((entry) => entry.path !== currentWorktree && !entry.path.endsWith(".git"));

if (available.length === 0) {
  console.log("No other worktrees available to switch to.");
  process.exit(0);
}

const fzfLines = available.map((entry) => path.basename(entry.path));

const selected = fzf(fzfLines, '--reverse --header="Select worktree to switch to >"');
if (selected === "") {
  process.exit(0);
}

const worktreePath = path.join(ctx.parentDir, selected);

let selectedBranch = selected;
const entry = available.find((candidate) => candidate.path === worktreePath);
if (entry) {
  selectedBranch = entry.branch;
}

const sname = sessionName(ctx.orgName, ctx.repoName, selectedBranch);
if (!tmuxSwitchOrCreate(sname, worktreePath)) {
  console.log(`Not in tmux, changing directory to ${worktreePath}`);
  exec(`cd ${shellQuote(worktreePath)} && exec $SHELL`);
}
