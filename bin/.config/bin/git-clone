#!/usr/bin/env luajit

-- Add script directory to package path
local script_dir = arg[0]:match("^(.+)/[^/]+$") or "."
package.path = script_dir .. "/?.lua;" .. package.path

local u = require("utils")

local ROOT_DIR = os.getenv("HOME") .. "/workspaces"

-- Parse arguments
local bare = false
local repo = nil

local i = 1
while i <= #arg do
	if arg[i] == "--bare" then
		bare = true
	else
		repo = arg[i]
	end
	i = i + 1
end

if not repo then
	io.stderr:write("Error: A repository to clone must be provided\n")
	os.exit(1)
end

-- Extract org/repo from URL or short form
local org_repo

if repo:match("://") or repo:match("@") then
	-- Full URL: extract org/repo
	org_repo = repo:gsub("/$", ""):match("([^/:]+/[^/:]+)$"):gsub("%.git$", "")
elseif repo:match("/") then
	-- Short form: org/repo
	org_repo = repo
	print("Assuming GitHub repository: https://github.com/" .. org_repo .. ".git")
	repo = "https://github.com/" .. org_repo .. ".git"
else
	io.stderr:write("Error: Repository must be in <org>/<repo> format or a full URL\n")
	os.exit(1)
end

local target_dir = ROOT_DIR .. "/" .. org_repo

if bare then
	local target_git_dir = target_dir .. "/.git"

	if u.exec(string.format('test -d "%s"', target_dir)) == 0 then
		io.stderr:write("Error: Target directory " .. target_dir .. " already exists\n")
		os.exit(1)
	end

	u.exec(string.format('mkdir -p "%s"', target_dir))

	print("Cloning bare " .. repo .. " into " .. target_git_dir .. "...")
	u.exec(string.format('git clone --bare "%s" "%s"', repo, target_git_dir))

	local default_branch = u.default_branch(target_git_dir)
	print("Default branch is: " .. default_branch)

	local worktree_path = target_dir .. "/" .. default_branch
	print("Adding worktree for " .. default_branch .. " at " .. worktree_path .. "...")
	u.exec(string.format('git -C "%s" worktree add "%s" "%s"', target_git_dir, worktree_path, default_branch))

	u.trust_mise(worktree_path)
else
	print("Cloning " .. repo .. " into " .. target_dir .. "...")
	u.exec(string.format('git clone "%s" "%s"', repo, target_dir))

	u.trust_mise(target_dir)
end

print("Successfully set up repository at " .. target_dir)
