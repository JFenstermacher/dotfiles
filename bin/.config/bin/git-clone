#!/usr/bin/env bun

import path from "node:path";
import { exec, shellQuote, defaultBranch, trustMise } from "./utils.js";

const rootDir = path.join(process.env.HOME ?? "", "workspaces");

let bare = false;
let repo = null;

for (const arg of process.argv.slice(2)) {
  if (arg === "--bare") {
    bare = true;
  } else {
    repo = arg;
  }
}

if (!repo) {
  console.error("Error: A repository to clone must be provided");
  process.exit(1);
}

let orgRepo;
if (repo.includes("://") || repo.includes("@")) {
  orgRepo = repo.replace(/\/$/, "").match(/([^/:]+\/[^/:]+)$/)?.[1]?.replace(/\.git$/, "");
} else if (repo.includes("/")) {
  orgRepo = repo;
  console.log(`Assuming GitHub repository: https://github.com/${orgRepo}.git`);
  repo = `https://github.com/${orgRepo}.git`;
} else {
  console.error("Error: Repository must be in <org>/<repo> format or a full URL");
  process.exit(1);
}

if (!orgRepo) {
  console.error("Error: Could not determine <org>/<repo> from repository");
  process.exit(1);
}

const targetDir = path.join(rootDir, orgRepo);

if (bare) {
  const targetGitDir = path.join(targetDir, ".git");

  if (exec(`test -d ${shellQuote(targetDir)}`) === 0) {
    console.error(`Error: Target directory ${targetDir} already exists`);
    process.exit(1);
  }

  exec(`mkdir -p ${shellQuote(targetDir)}`);

  console.log(`Cloning bare ${repo} into ${targetGitDir}...`);
  exec(`git clone --bare ${shellQuote(repo)} ${shellQuote(targetGitDir)}`);
  exec(`git -C ${shellQuote(targetGitDir)} config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"`);

  const branch = defaultBranch(targetGitDir);
  console.log(`Default branch is: ${branch}`);

  const worktreePath = path.join(targetDir, branch);
  console.log(`Adding worktree for ${branch} at ${worktreePath}...`);
  exec(`git -C ${shellQuote(targetGitDir)} worktree add ${shellQuote(worktreePath)} ${shellQuote(branch)}`);

  trustMise(worktreePath);
} else {
  console.log(`Cloning ${repo} into ${targetDir}...`);
  exec(`git clone ${shellQuote(repo)} ${shellQuote(targetDir)}`);

  trustMise(targetDir);
}

console.log(`Successfully set up repository at ${targetDir}`);
