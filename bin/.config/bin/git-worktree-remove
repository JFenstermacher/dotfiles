#!/usr/bin/env bun

import path from "node:path";
import { defaultBranch, exec, execCapture, fzf, getWorktreeBranches, requireBareRepo, repoContext, sessionName, shellQuote, tmuxKillSession } from "./utils.js";

const gitDir = requireBareRepo();
const ctx = repoContext(gitDir);
const defaultBranchName = defaultBranch(gitDir);
const currentWorktree = execCapture("git rev-parse --show-toplevel 2>/dev/null").replace(/\s+$/g, "");

const worktrees = getWorktreeBranches(gitDir);

const removable = worktrees.filter(
  (entry) => entry.path !== currentWorktree && !entry.path.endsWith(".git") && entry.branch !== defaultBranchName,
);

if (removable.length === 0) {
  console.log("No worktrees available to remove (excluding current and default branch).");
  process.exit(0);
}

const fzfLines = removable.map((entry) => path.basename(entry.path));

const selected = fzf(fzfLines, '--multi --reverse --header="Select worktrees to remove (Tab to multi-select) >"');
if (selected === "") {
  process.exit(0);
}

for (const line of selected.split(/\n/).filter(Boolean)) {
  const relPath = line;
  const worktreePath = path.join(ctx.parentDir, relPath);

  const entry = removable.find((candidate) => candidate.path === worktreePath);
  const branch = entry?.branch;

  console.log(`Processing ${relPath} (branch: ${branch ?? "unknown"}) at ${worktreePath}...`);

  if (branch) {
    const sname = sessionName(ctx.orgName, ctx.repoName, branch);
    tmuxKillSession(sname);
  }

  console.log(`Removing worktree ${relPath}...`);
  exec(`git -C ${shellQuote(gitDir)} worktree remove --force ${shellQuote(worktreePath)}`);
}

console.log("Done.");
