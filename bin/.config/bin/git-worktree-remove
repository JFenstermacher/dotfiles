#!/usr/bin/env luajit

-- Add script directory to package path
local script_dir = arg[0]:match("^(.+)/[^/]+$") or "."
package.path = script_dir .. "/?.lua;" .. package.path

local wt = require("utils")

local git_dir = wt.require_bare_repo()
local ctx = wt.repo_context(git_dir)
local default_branch = wt.default_branch(git_dir)
local current_worktree = wt.exec_capture("git rev-parse --show-toplevel 2>/dev/null"):gsub("%s+$", "")

local worktrees = wt.get_worktree_branches(git_dir)

-- Build list of removable worktrees (exclude current, bare repo, default branch)
local removable = {}
for _, entry in ipairs(worktrees) do
	if entry.path ~= current_worktree
		and not entry.path:match("%.git$")
		and entry.branch ~= default_branch then
		removable[#removable + 1] = entry
	end
end

if #removable == 0 then
	print("No worktrees available to remove (excluding current and default branch).")
	os.exit(0)
end

local fzf_lines = {}
for _, entry in ipairs(removable) do
	fzf_lines[#fzf_lines + 1] = entry.path:match("^.+/([^/]+)$")
end

local selected = wt.fzf(fzf_lines, '--multi --reverse --header="Select worktrees to remove (Tab to multi-select) >"')
if selected == "" then
	os.exit(0)
end

for line in selected:gmatch("[^\n]+") do
	local rel_path = line
	local path = ctx.parent_dir .. "/" .. rel_path

	-- Find the branch for this worktree
	local branch = nil
	for _, entry in ipairs(removable) do
		if entry.path == path then
			branch = entry.branch
			break
		end
	end

	print("Processing " .. rel_path .. " (branch: " .. (branch or "unknown") .. ") at " .. path .. "...")

	if branch then
		local sname = wt.session_name(ctx.org_name, ctx.repo_name, branch)
		wt.tmux_kill_session(sname)
	end

	print("Removing worktree " .. rel_path .. "...")
	wt.exec(string.format('git -C "%s" worktree remove --force "%s"', git_dir, path))
end

print("Done.")
