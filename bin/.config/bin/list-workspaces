#!/usr/bin/env luajit

-- Add script directory to package path
local script_dir = arg[0]:match("^(.+)/[^/]+$") or "."
package.path = script_dir .. "/?.lua;" .. package.path

local u = require("utils")

local ROOT_DIR = arg[1] or os.getenv("HOME") .. "/workspaces"

local find_cmd = string.format("fd --hidden --min-depth 2 --type d --max-depth 2 . %s", ROOT_DIR)
local found_paths = u.exec_lines(find_cmd)

local repos = {}
for _, path in ipairs(found_paths) do
	local no_prefix = path:gsub("^" .. ROOT_DIR .. "/", "")
	local no_suffix = no_prefix:sub(1, -2)

	repos[#repos + 1] = no_suffix
end

for _, repo in ipairs(repos) do
	print(repo)
end
