#!/usr/bin/env bun

import path from "node:path";
import { execLines, shellQuote } from "./utils.js";

const rootDir = process.argv[2] ?? path.join(process.env.HOME ?? "", "workspaces");

const foundPaths = execLines(`fd --hidden --min-depth 2 --type d --max-depth 2 . ${shellQuote(rootDir)}`);

for (const foundPath of foundPaths) {
  const relative = foundPath.startsWith(`${rootDir}/`) ? foundPath.slice(rootDir.length + 1) : foundPath;
  console.log(relative.replace(/\/$/, ""));
}
