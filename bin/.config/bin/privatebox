#!/bin/sh

set -eu

# Resolve this script's real location without relying on GNU readlink -f or
# realpath, so this works on both macOS and Linux when invoked through a
# symlink in ~/.config/bin.
resolve_script_path() {
	path=$1

	case $path in
		*/*) ;;
		*)
			# If invoked by name through PATH, recover the executable path first.
			found=$(command -v -- "$path" 2>/dev/null || true)
			if [ -n "$found" ]; then
				path=$found
			fi
			;;
	esac

	seen=0
	while [ -L "$path" ]; do
		seen=$((seen + 1))
		if [ "$seen" -gt 40 ]; then
			echo "privatebox: too many symlink levels while resolving $1" >&2
			exit 1
		fi

		dir=$(CDPATH= cd -P -- "$(dirname -- "$path")" >/dev/null 2>&1 && pwd)
		link=$(readlink -- "$path")

		case $link in
			/*) path=$link ;;
			*) path=$dir/$link ;;
		esac
	done

	dir=$(CDPATH= cd -P -- "$(dirname -- "$path")" >/dev/null 2>&1 && pwd)
	base=$(basename -- "$path")
	printf '%s/%s\n' "$dir" "$base"
}

script_path=$(resolve_script_path "$0")
script_dir=$(dirname -- "$script_path")
repo_root=$(CDPATH= cd -P -- "$script_dir/../../.." >/dev/null 2>&1 && pwd)
app_dir=$repo_root/apps/privatebox

if [ ! -f "$app_dir/src/index.ts" ]; then
	echo "privatebox: expected app entrypoint not found: $app_dir/src/index.ts" >&2
	exit 1
fi

if ! command -v bun >/dev/null 2>&1; then
	echo "privatebox: bun is required but was not found in PATH" >&2
	exit 127
fi

cd "$app_dir"
exec bun run src/index.ts "$@"
