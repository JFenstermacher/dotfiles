#!/usr/bin/env bun

import { exec, execCapture, inTmux, shellQuote, trim } from "./utils.js";

const userSession = trim(execCapture("whoami"));
const home = process.env.HOME ?? "";

function createUserSession() {
  if (exec(`tmux has-session -t ${shellQuote(userSession)} 2>/dev/null`) !== 0) {
    exec(`TMUX="" tmux new-session -d -s ${shellQuote(userSession)} -c ${shellQuote(home)}`);
  }
}

if (inTmux()) {
  createUserSession();
  exec(`tmux switch-client -t ${shellQuote(userSession)}`);
} else if (exec("tmux list-sessions >/dev/null 2>&1") === 0) {
  createUserSession();
  exec(`tmux attach-session -t ${shellQuote(userSession)}`);
} else {
  exec(`tmux new-session -s ${shellQuote(userSession)} -c ${shellQuote(home)}`);
}
