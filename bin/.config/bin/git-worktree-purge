#!/usr/bin/env luajit

-- Add script directory to package path
local script_dir = arg[0]:match("^(.+)/[^/]+$") or "."
package.path = script_dir .. "/?.lua;" .. package.path

local wt = require("utils")

local git_dir = wt.require_bare_repo()
local ctx = wt.repo_context(git_dir)
local default_branch = wt.default_branch(git_dir)
local current_worktree = wt.exec_capture("git rev-parse --show-toplevel 2>/dev/null"):gsub("%s+$", "")

-- Get merged branches
local merged_output = wt.exec_capture(string.format('git -C "%s" branch --format="%%(refname:short)" --merged "%s"', git_dir, default_branch))
local merged_set = {}
for line in merged_output:gmatch("[^\n]+") do
	merged_set[line] = true
end

local worktrees = wt.get_worktree_branches(git_dir)

for _, entry in ipairs(worktrees) do
	if entry.path == current_worktree then
		goto continue
	end
	if entry.path:match("%.git$") then
		goto continue
	end
	if entry.branch == default_branch then
		goto continue
	end

	if merged_set[entry.branch] then
		local rel_path = entry.path:match("^.+/([^/]+)$")
		print("Purging merged worktree " .. rel_path .. " (branch: " .. entry.branch .. ") at " .. entry.path .. "...")

		local sname = wt.session_name(ctx.org_name, ctx.repo_name, entry.branch)
		wt.tmux_kill_session(sname)

		print("Removing worktree " .. rel_path .. "...")
		wt.exec(string.format('git -C "%s" worktree remove --force "%s"', git_dir, entry.path))

		print("Deleting merged branch " .. entry.branch .. "...")
		wt.exec(string.format('git -C "%s" branch -d "%s" 2>/dev/null', git_dir, entry.branch))
	end

	::continue::
end

print("Purge complete.")
