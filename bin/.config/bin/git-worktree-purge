#!/usr/bin/env bun

import path from "node:path";
import { defaultBranch, exec, execCapture, getWorktreeBranches, requireBareRepo, repoContext, sessionName, shellQuote, tmuxKillSession } from "./utils.js";

const gitDir = requireBareRepo();
const ctx = repoContext(gitDir);
const defaultBranchName = defaultBranch(gitDir);
const currentWorktree = execCapture("git rev-parse --show-toplevel 2>/dev/null").replace(/\s+$/g, "");

const mergedOutput = execCapture(
  `git -C ${shellQuote(gitDir)} branch --format="%(refname:short)" --merged ${shellQuote(defaultBranchName)}`,
);
const mergedSet = new Set(mergedOutput.split(/\n/).filter(Boolean));

const worktrees = getWorktreeBranches(gitDir);

for (const entry of worktrees) {
  if (entry.path === currentWorktree) {
    continue;
  }
  if (entry.path.endsWith(".git")) {
    continue;
  }
  if (entry.branch === defaultBranchName) {
    continue;
  }

  if (mergedSet.has(entry.branch)) {
    const relPath = path.basename(entry.path);
    console.log(`Purging merged worktree ${relPath} (branch: ${entry.branch}) at ${entry.path}...`);

    const sname = sessionName(ctx.orgName, ctx.repoName, entry.branch);
    tmuxKillSession(sname);

    console.log(`Removing worktree ${relPath}...`);
    exec(`git -C ${shellQuote(gitDir)} worktree remove --force ${shellQuote(entry.path)}`);

    console.log(`Deleting merged branch ${entry.branch}...`);
    exec(`git -C ${shellQuote(gitDir)} branch -d ${shellQuote(entry.branch)} 2>/dev/null`);
  }
}

console.log("Purge complete.");
