#!/usr/bin/env bun

import path from "node:path";
import { createWorktree, defaultBranch, execCapture, fzf, getWorktreeBranches, requireBareRepo, repoContext, sessionName, shellQuote, tmuxSwitchOrCreate, trustMise } from "./utils.js";

const gitDir = requireBareRepo();
const ctx = repoContext(gitDir);

const worktrees = getWorktreeBranches(gitDir);
const wtMap = new Map(worktrees.map((entry) => [entry.branch, entry.path]));

const output = execCapture(`git -C ${shellQuote(gitDir)} branch -a --no-color`);
const seen = new Set();
const allBranches = [];

for (const line of output.split(/\n/)) {
  let name = line.replace(/^[\s*]+/, "");
  if (!name || name.includes("->")) {
    continue;
  }
  name = name.replace(/^remotes\/[^/]+\//, "");
  if (!seen.has(name)) {
    seen.add(name);
    allBranches.push(name);
  }
}
allBranches.sort();

const fzfInput = allBranches.map((branch) => wtMap.has(branch) ? `[wt] ${branch}` : branch);

if (fzfInput.length === 0) {
  console.error("No branches found.");
  process.exit(1);
}

const selected = fzf(fzfInput, '--reverse --header="Select branch >"');
if (selected === "") {
  process.exit(1);
}

const hasWorktree = selected.startsWith("[wt] ");
const branchName = selected.replace(/^\[wt\] /, "");
const sname = sessionName(ctx.orgName, ctx.repoName, branchName);

if (hasWorktree) {
  const worktreePath = wtMap.get(branchName);
  if (!tmuxSwitchOrCreate(sname, worktreePath)) {
    console.error(`Not in tmux. Worktree path: ${worktreePath}`);
  }
} else {
  const worktreePath = path.join(ctx.parentDir, branchName);
  createWorktree(gitDir, worktreePath, branchName);
  trustMise(worktreePath);

  if (!tmuxSwitchOrCreate(sname, worktreePath)) {
    console.error(`Worktree created at: ${worktreePath}`);
  }
}
