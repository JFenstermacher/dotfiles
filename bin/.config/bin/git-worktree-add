#!/usr/bin/env luajit

-- Add script directory to package path
local script_dir = arg[0]:match("^(.+)/[^/]+$") or "."
package.path = script_dir .. "/?.lua;" .. package.path

local wt = require("utils")

local branch_name = arg[1]

if not branch_name or branch_name == "" then
	io.write("Worktree Name: ")
	branch_name = io.read()
end

if not branch_name or branch_name == "" then
	io.stderr:write("Error: Branch name is required.\n")
	os.exit(1)
end

if not branch_name:match("^[A-Za-z0-9_/-]+$") then
	io.stderr:write("Error: Branch name '" .. branch_name .. "' contains invalid characters.\n")
	io.stderr:write("Branch names can only contain: letters, numbers, hyphens, underscores, and slashes.\n")
	os.exit(1)
end

local git_dir = wt.require_git_dir()
local ctx = wt.repo_context(git_dir)
local worktree_path = ctx.parent_dir .. "/" .. branch_name

if wt.exec(string.format('test -d "%s"', worktree_path)) == 0 then
	io.stderr:write("Error: Worktree path " .. worktree_path .. " already exists.\n")
	os.exit(1)
end

print("Creating worktree for branch '" .. branch_name .. "' in " .. worktree_path .. "...")

wt.create_worktree(git_dir, worktree_path, branch_name)
wt.trust_mise(worktree_path)

local sname = wt.session_name(ctx.org_name, ctx.repo_name, branch_name)
print("Creating tmux session '" .. sname .. "'...")
if not wt.tmux_switch_or_create(sname, worktree_path) then
	print("Not in tmux. Worktree created at: " .. worktree_path)
end

print("Done.")
