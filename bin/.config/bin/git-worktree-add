#!/usr/bin/env bun

import path from "node:path";
import { createWorktree, exec, requireGitDir, repoContext, sessionName, shellQuote, tmuxSwitchOrCreate, trustMise } from "./utils.js";

async function prompt(message) {
  process.stdout.write(message);
  for await (const line of console) {
    return line;
  }
  return "";
}

let branchName = process.argv[2];

if (!branchName) {
  branchName = await prompt("Worktree Name: ");
}

if (!branchName) {
  console.error("Error: Branch name is required.");
  process.exit(1);
}

if (!/^[A-Za-z0-9_/-]+$/.test(branchName)) {
  console.error(`Error: Branch name '${branchName}' contains invalid characters.`);
  console.error("Branch names can only contain: letters, numbers, hyphens, underscores, and slashes.");
  process.exit(1);
}

const gitDir = requireGitDir();
const ctx = repoContext(gitDir);
const worktreePath = path.join(ctx.parentDir, branchName);

if (exec(`test -d ${shellQuote(worktreePath)}`) === 0) {
  console.error(`Error: Worktree path ${worktreePath} already exists.`);
  process.exit(1);
}

console.log(`Creating worktree for branch '${branchName}' in ${worktreePath}...`);

createWorktree(gitDir, worktreePath, branchName);
trustMise(worktreePath);

const sname = sessionName(ctx.orgName, ctx.repoName, branchName);
console.log(`Creating tmux session '${sname}'...`);
if (!tmuxSwitchOrCreate(sname, worktreePath)) {
  console.log(`Not in tmux. Worktree created at: ${worktreePath}`);
}

console.log("Done.");
