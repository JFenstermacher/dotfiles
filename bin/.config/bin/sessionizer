#!/usr/bin/env bun

import path from "node:path";
import { defaultBranch, exec, execCapture, inTmux, shellQuote, trim } from "./utils.js";

let dir = process.argv[2];

if (!dir) {
  if (!inTmux()) {
    if (exec("tmux attach") === 0) {
      process.exit(1);
    }
    dir = "--start";
  } else {
    process.exit(1);
  }
}

let sname = "";
let pathName = "";

if (dir === "--start") {
  const pwd = process.env.PWD ?? process.cwd();
  const basename = path.basename(pwd);
  pathName = basename.replace(/\./g, "-");
  sname = pathName.replace(/\./g, "_");
} else {
  const selected = execCapture(
    `list-workspaces ${shellQuote(dir)} | fzf --reverse --header=${shellQuote(`Select project from $(basename ${dir}) >`)}`,
  ).replace(/\n/g, "");

  if (selected === "") {
    process.exit(1);
  }

  sname = selected;
  pathName = path.join(dir, selected);

  const branch = defaultBranch(pathName);
  const candidatePath = path.join(pathName, branch);
  if (exec(`test -d ${shellQuote(candidatePath)}`) === 0) {
    pathName = candidatePath;
    sname = `${selected}@${branch}`;
  }
}

console.log(`session name is "${sname}"`);
console.log(`path name is ${pathName}`);

function sessionExists() {
  return exec(`tmux has-session -t ${shellQuote(`=${sname}`)}`) === 0;
}

function createDetachedSession() {
  exec(`TMUX="" tmux new-session -Ad -s ${shellQuote(sname)} -c ${shellQuote(pathName)}`);
  if (dir !== "--start") {
    exec(`tmux send-keys -t ${shellQuote(sname)} "nvim" Enter`);
  }
}

function createIfNeededAndAttach() {
  if (!inTmux()) {
    return exec(`tmux new-session -As ${shellQuote(sname)} -c ${shellQuote(pathName)}`) === 0;
  }

  if (!sessionExists()) {
    createDetachedSession();
  }
  return exec(`tmux switch-client -t ${shellQuote(sname)}`) === 0;
}

function attachToFirstSession() {
  const target = trim(execCapture('tmux list-sessions -F "#{session_name}" | head -n 1'));
  if (target !== "") {
    exec(`tmux attach -t ${shellQuote(target)}`);
    exec("tmux choose-tree -Za");
  }
}

if (!createIfNeededAndAttach()) {
  attachToFirstSession();
}
