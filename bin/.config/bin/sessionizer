#!/usr/bin/env luajit

-- Add script directory to package path
local script_dir = arg[0]:match("^(.+)/[^/]+$") or "."
package.path = script_dir .. "/?.lua;" .. package.path

local u = require("utils")

local dir = arg[1]

-- If no arguments, try to attach or default to --start
if not dir or dir == "" then
	if not u.in_tmux() then
		if u.exec("tmux attach") == 0 then
			os.exit(1)
		else
			dir = "--start"
		end
	else
		os.exit(1)
	end
end

local sname = ""
local path_name = ""

if dir == "--start" then
	local pwd = os.getenv("PWD")
	local basename = pwd:match("^.+/(.+)$") or pwd
	path_name = basename:gsub("%.", "-")
	sname = path_name:gsub("%.", "_")
else
	local cmd =
		string.format('list-workspaces %s | fzf --reverse --header="Select project from $(basename %s) >"', dir, dir)
	local selected = u.exec_capture(cmd):gsub("\n", "")

	if selected == "" then
		os.exit(1)
	end

	-- ~/workspaces/{selection}
	sname = selected
	path_name = dir .. "/" .. selected

	-- is worktree?
	local default_branch = u.default_branch(path_name)
	local candidate_path = path_name .. "/" .. default_branch
	if u.exec(string.format("test -d %s", candidate_path)) == 0 then
		path_name = candidate_path
		sname = selected .. "@" .. default_branch
	end
end

print('session name is "' .. sname .. '"')
print("path name is " .. path_name)

local function session_exists()
	return u.exec('tmux has-session -t "=' .. sname .. '"') == 0
end

local function create_detached_session()
	if dir == "--start" then
		u.exec(string.format('TMUX="" tmux new-session -Ad -s "%s" -c "%s"', sname, path_name))
	else
		u.exec(string.format('TMUX="" tmux new-session -Ad -s "%s" -c "%s"', sname, path_name))
		u.exec(string.format('tmux send-keys -t "%s" "nvim" Enter', sname))
	end
end

local function create_if_needed_and_attach()
	if not u.in_tmux() then
		return u.exec(string.format('tmux new-session -As "%s" -c "%s"', sname, path_name)) == 0
	else
		if not session_exists() then
			create_detached_session()
		end
		return u.exec(string.format('tmux switch-client -t "%s"', sname)) == 0
	end
end

local function attach_to_first_session()
	local target = u.trim(u.exec_capture('tmux list-sessions -F "#{session_name}" | head -n 1'))
	if target ~= "" then
		u.exec('tmux attach -t "' .. target .. '"')
		u.exec("tmux choose-tree -Za")
	end
end

if not create_if_needed_and_attach() then
	attach_to_first_session()
end
