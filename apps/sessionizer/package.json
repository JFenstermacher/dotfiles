{
  "name": "@dotfiles/sessionizer",
  "version": "0.1.0",
  "private": true,
  "description": "Tmux workspace manager — syncs repos, branches, and PRs from GitHub, manages tmux sessions and worktrees",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vp pack"
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command@^1.2.1",
    "@dotfiles/envs": "workspace:*",
    "@dotfiles/git": "workspace:*",
    "@dotfiles/logger": "workspace:*",
    "@dotfiles/tmux": "workspace:*",
    "better-result": "^2.9.2",
    "drizzle-orm": "1.0.0-rc.4-273829f",
    "node-cron": "^4.2.1",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/proper-lockfile": "^4.1.4",
    "drizzle-kit": "1.0.0-rc.4-273829f",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.24"
  },
  "engines": {
    "node": ">=20.0.0"
  }
